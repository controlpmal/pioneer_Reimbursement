@section Scripts {
    <script src="~/lib/axios/dist/axios.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const empid = "@empid";
            const designation = "@designation";

            function reload() {
                axios.get(`/api/dashboard/pending?empid=${empid}&designation=${designation}`)
                    .then(res => document.getElementById("pendingCount").innerText = res.data);
                axios.get(`/api/dashboard/approved?empid=${empid}&designation=${designation}`)
                    .then(res => document.getElementById("approvedCount").innerText = res.data);
                axios.get(`/api/dashboard/rejected?empid=${empid}&designation=${designation}`)
                    .then(res => document.getElementById("rejectedCount").innerText = res.data);
                       axios.get(`/api/dashboard/checked?empid=${empid}&designation=${designation}`)
                    .then(res => document.getElementById("checkedCount").innerText = res.data);
            }

            reload();
            setInterval(reload, 5000);

              if (designation === "ACCOUNTS") {
                document.getElementById("accountCard").style.display = "flex";




                function loadImpressCountFromHr() {
                    axios.get(`/api/dashboard/impress-pendingaccounts`)
                        .then(res => document.getElementById("impressCountFromHr").innerText = res.data)
                        .catch(err => console.error("Error loading Impress count:", err));
                }


                loadImpressCountFromHr();

                setInterval(() => {

                    loadImpressCountFromHr();
                }, 10000);
            }

            //Head impress card enable code
             if (designation === "Head") {
                document.getElementById("HeadCard").style.display = "flex";

                function loadImpressCount1() {
                    axios.get(`/api/dashboard/impress-pending`)
                        .then(res => document.getElementById("impressCount1").innerText = res.data)
                        .catch(err => console.error("Error loading Impress count:", err));
                }
                        loadImpressCount1();

                setInterval(() => {

                    loadImpressCount1();
                }, 10000);

                  }

            //AGM IMPRESS REQUESTR CARD VALUE SHOW


                                // Show AGM card if designation is AGM or Consultant
        if (designation === "AGM" || designation === "Consultant") {
            document.getElementById("agmCard").style.display = "flex";
        }

        // Function to load Impress Request count
        function loadImpressCountFromHrJ() {
            axios.get(`/api/dashboard/impress-pendingagm`)
                .then(res => document.getElementById("impressCountFromHrJ").innerText = res.data)
                .catch(err => console.error("Error loading Impress count:", err));
        }

        // Function to load Project Expense
                function loadTotalImpress() {
            axios.get(`/api/dashboard/Total-approved`)
                .then(res => {
                    // Format number with commas and add rupee symbol
                    const formattedAmount = `₹${Number(res.data).toLocaleString('en-IN')}`;
                    document.getElementById("projectExpense").innerText = formattedAmount;
                })
                .catch(err => console.error("Error loading Project Expense:", err));
        }


        // Call functions based on designation
        if (designation === "AGM" || designation === "Consultant") {
            loadImpressCountFromHrJ();
            setInterval(loadImpressCountFromHrJ, 10000);
        }

        if (designation === "AGM") {
            loadTotalImpress();
            setInterval(loadTotalImpress, 10000);
        }


            if (designation === "HR") {
                document.getElementById("hrCards").style.display = "flex";

                function loadNewEmployees() {
                    axios.get(`/api/employee/new`)
                        .then(res => {
                            const preview = document.getElementById("employeePreview");
                            preview.innerHTML = "";
                            res.data.forEach(emp => {
                                const li = document.createElement("li");
                                li.textContent = emp.empName;
                                preview.appendChild(li);
                            });
                        })
                        .catch(err => console.error("Error loading new employees:", err));
                }

                function loadImpressCount() {
                    axios.get(`/api/dashboard/impress-pending`)
                        .then(res => document.getElementById("impressCount").innerText = res.data)
                        .catch(err => console.error("Error loading Impress count:", err));
                }

                loadNewEmployees();
                loadImpressCount();

                setInterval(() => {
                    loadNewEmployees();
                    loadImpressCount();
                }, 10000);
            }
        });


        //sweet alert
          // Success Alert
        function showSuccess(msg) {
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: msg,
                showConfirmButton: false,
                timer: 1500
            });
        }

        // Error Alert
        function showError(msg) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: msg
            });
        }

        // Confirmation Alert
        function showConfirm(msg) {
            return Swal.fire({
                title: 'Confirm',
                text: msg,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes',
                cancelButtonText: 'No'
            });
        }

    </script>
}
