                       async function downloadImagesAsPDF() {
            showLoader();

            try {
                const { PDFDocument } = PDFLib;
                const mergedPdf = await PDFDocument.create();

                const rows = document.querySelectorAll("#itemsTable tbody tr");

                for (const tr of rows) {
                    const id = tr.getAttribute("data-id");
                    if (!id) continue;

                    try {
                        const res = await axios.get(`/api/dashboard/GetBillInfo/${id}`);
                        let { fileUrl, contentType } = res.data;

                        if (!fileUrl) continue;

                        contentType = (contentType || "").toLowerCase();

                        // ✅ If file is PDF → merge it
                        if (contentType === "application/pdf") {

                            const existingPdfBytes = await fetch(fileUrl).then(res => res.arrayBuffer());
                            const existingPdf = await PDFDocument.load(existingPdfBytes);

                            const copiedPages = await mergedPdf.copyPages(
                                existingPdf,
                                existingPdf.getPageIndices()
                            );

                            copiedPages.forEach(page => {
                                mergedPdf.addPage(page);
                            });
                        }

                        // ✅ If file is Image → convert to PDF page
                        else if (contentType.startsWith("image/")) {

                            const imageBytes = await fetch(fileUrl).then(res => res.arrayBuffer());

                            let image;
                            if (contentType === "image/png") {
                                image = await mergedPdf.embedPng(imageBytes);
                            } else {
                                image = await mergedPdf.embedJpg(imageBytes);
                            }

                            const page = mergedPdf.addPage();
                            const { width, height } = page.getSize();

                            page.drawImage(image, {
                                x: 20,
                                y: 20,
                                width: width - 40,
                                height: height - 40,
                            });
                        }

                    } catch (err) {
                        console.error("File error:", err);
                    }
                }

                const pdfBytes = await mergedPdf.save();

                const blob = new Blob([pdfBytes], { type: "application/pdf" });
                const url = URL.createObjectURL(blob);

                const a = document.createElement("a");
                a.href = url;
                a.download = "Merged_Files.pdf";
                a.click();

            } catch (err) {
                console.error("PDF generation error:", err);
            } finally {
                hideLoader();
            }
        }

