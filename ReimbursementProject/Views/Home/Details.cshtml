         //status of the class
                function getRowStatusClass(status, rejection) {
            if (rejection === "reject") return "row-rejected";

            switch (String(status)) {
                case "5": return "row-pending-posting";
                case "0": return "row-pending-irb";
                case "1": return "row-pending-hr";
                case "2": return "row-pending-admin";
                case "3": return "row-pending-accounts";
                case "4": return "row-approved";
                default: return "";
            }
        }

        //status trakcer
                function renderStatusTracker(status, empName = '') {
            const tracker = document.getElementById('statusTracker');
            tracker.innerHTML = ''; // clear previous

            const steps = [
                { id: 5, label: 'Pending Posting' },
                { id: 0, label: 'Pending at IRB' },
                { id: 1, label: 'Pending at HR' },
                { id: 2, label: 'Pending at HR Admin' },
                { id: 3, label: 'Pending at Accounts' },
                { id: 4, label: 'Approved' },
            ];

            steps.forEach((step, index) => {
                const stepDiv = document.createElement('div');
                stepDiv.classList.add('status-step');

                // Determine status
                if (step.id < status) {
                    stepDiv.classList.add('completed');
                } else if (step.id === status) {
                    stepDiv.classList.add('pending');
                }

                // Special case: show employee name if pending posting
                let circleContent = '';
                if (step.id === 5 && status === 5 && empName) {
                    circleContent = '👤';
                } else {
                    circleContent = step.id;
                }

                stepDiv.innerHTML = `
                    <div class="circle">${circleContent}</div>
                    <div class="label">${step.label}</div>
                `;

                tracker.appendChild(stepDiv);
            });
        }
