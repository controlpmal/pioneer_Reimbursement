                async function submitGroupReject() {
                    const reason = document.getElementById("groupRejectReason").value.trim();

                    if (!reason) {
                        showError("Please enter rejection reason.");
                        return;
                    }

                    showLoader();

                    try {
                        await axios.post('/api/dashboard/reject-group', {
                            EmpID: currentEmpID,
