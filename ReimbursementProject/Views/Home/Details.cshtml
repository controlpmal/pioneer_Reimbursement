                         async function viewBill(id) {
                    showLoader();
                    try {
                        const res = await axios.get(`/api/dashboard/GetBillInfo/${id}`);
                        let { fileUrl, contentType, fileName } = res.data;

                        contentType = (contentType || "").toLowerCase().split(";")[0].trim();

                        const frame = document.getElementById("fileViewerFrame");
                        const excelContainer = document.getElementById("excelContainer");
                        const msg = document.getElementById("unsupportedMsg");
                        const downloadBtn = document.getElementById("downloadBtn");

                        // Reset modal content
                        frame.style.display = "none";
                        frame.src = "";
                        excelContainer.style.display = "none";
                        excelContainer.innerHTML = "";
                                // ✅ Reset image container and viewer
                const imageContainer = document.getElementById("imageContainer");
                const imageViewer = document.getElementById("imageViewer");
                              imageContainer.style.display = "none";
                        imageViewer.src = "";
                        msg.style.display = "none";
                        downloadBtn.style.display = "none";

                        // Always enable download if URL exists
                        if (fileUrl) {
                            downloadBtn.href = fileUrl;
                            downloadBtn.download = fileName || "file";
                            downloadBtn.style.display = "inline-block";
                        }

                        // File type handling
                        if (contentType.includes("spreadsheet") || contentType.includes("excel") || contentType === "text/csv") {
                            excelContainer.style.display = "block";

                            const blobRes = await axios.get(fileUrl, { responseType: "arraybuffer" });
                            const data = new Uint8Array(blobRes.data);
                            const workbook = XLSX.read(data, { type: "array" });
                            const firstSheet = workbook.SheetNames[0];
                            excelContainer.innerHTML = XLSX.utils.sheet_to_html(workbook.Sheets[firstSheet]);

                        } else if (contentType.startsWith("image/")) {
                                      // ✅ Use <img> instead of iframe for images
                    document.getElementById("imageContainer").style.display = "block";
                    document.getElementById("imageViewer").src = fileUrl;
                            // frame.style.display = "block";
                            // frame.src = fileUrl;

                        } else if (contentType === "application/pdf") {
                            frame.style.display = "block";
                            frame.src = fileUrl + "#toolbar=1";

                        } else {
                            // Unsupported format message already shown, download always visible
                            msg.style.display = "block";
                        }

                        new bootstrap.Modal(document.getElementById("fileViewerModal")).show();

                    } catch (err) {
                        console.error("Error viewing file:", err);
                        // alert("Could not open file for viewing.");
                                showError("Could not open file for viewing.");
                    } finally {
                        hideLoader();
                    }
                }







