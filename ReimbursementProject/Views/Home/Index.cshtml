            let nextRowId = 0;

                   function formatDateIso(d) {
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const dd = String(d.getDate()).padStart(2, "0");
            return `${yyyy}-${mm}-${dd}`;  // ✅ ISO format works with ASP.NET DateTime
        }
            function isTravelType(t) {
                if (!t) return false;
                const tt = t.toUpperCase();
                return tt.includes("TRAVEL BIKE") || tt.includes("TRAVEL CAR");
            }
            function isHotelType(t){
                                if (!t) return false;
                const tt = t.toUpperCase();
                return tt.includes("HOTEL ROOM/DAY");

            }
            function isTransportType(t) {
                if (!t) return false;
                const tt = t.toUpperCase();
                return tt.includes("PUBLIC TRANSPORT")||tt.includes("TICKET");
            }
            function isOtherType(t){
                if(!t) return false;
                const tt = t.toUpperCase();
                return tt.includes("OTHER");
            }

            // load dropdowns
            axios.get(expenseTypesApi).then(res => {
                expenseTypes = res.data || [];
                const sel = $("#expenseTypeSelect").empty();
                sel.append(`<option value="">-- Select type --</option>`);
                expenseTypes.forEach(e => {
                    const label = e.typeOfExpense ?? e.TypeOfExpense ?? e.Type ?? e;
                    sel.append(`<option value="${label}">${label}</option>`);
                });
            });
            axios.get(employeesApi).then(res => { employees = res.data || []; });



            //add row
                    $("#btnAddRange").click(async () => {
            const from = $("#fromDate").val();
            const to = $("#toDate").val();
            const type = $("#expenseTypeSelect").val();
            if (!from || !type) {
                // alert("Choose from date and expense type.");
                showError("Choose from date and expense type.");
                return;
            }

            const fromD = new Date(from);
            const toD = to ? new Date(to) : fromD;
            if (toD < fromD) {
                // alert("To date cannot be before From date.");
                showError("To date cannot be before From date.");
                return;
            }

            // ✅ Expense types that can have duplicates
            const allowDuplicateTypes = ["TRAVEL BIKE/KM", "TRAVEL CAR/KM", "PUBLIC TRANSPORT","TICKET", "TOLL","OTHER","FOOD","MATERIAL","TICKET","TRAVEL","HOTEL"];

            for (let dt = new Date(fromD); dt <= toD; dt.setDate(dt.getDate() + 1)) {
                const dateIso = formatDateIso(dt);

                // ✅ Check if duplicate allowed for this type
                const isDuplicateAllowed = allowDuplicateTypes.includes(type);

                // ✅ Check duplicates in current page (only if duplicates not allowed)
                let existsInPage = false;
                if (!isDuplicateAllowed) {
                    $("#expenseRows .expense-row").each(function () {
                        const d = $(this).find(".date-cell").val();
                        const t = $(this).find(".type-cell").val();
                        if (d === dateIso && t === type) {
                            existsInPage = true;
                            return false; // break loop
                        }
                    });
                }

                if (existsInPage) {
                    showError(`Row already exists for ${dateIso} (${type}).`);

                    continue;
                }

                // ✅ Check duplicates in DB (only if duplicates not allowed)
                if (!isDuplicateAllowed) {
                    try {
                        const res = await axios.get("/api/Employee/check-duplicate", {
                            params: { empId: EmpID, typeOfExpense: type, dateOfExpense: dateIso }
                        });
                        if (res.data.exists) {
                           showError(`Duplicate entry found in database for ${dateIso} (${type}).`);

                            continue;
                        }
                    } catch (err) {
                        console.error(err);
                    }
                }

                // ✅ Finally add row
                addRow(dateIso, type);
            }
        });

