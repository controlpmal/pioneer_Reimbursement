        $("#projectCode").on("input", function () {
            let val = $(this).val();

            // Only enforce PC- when user manually begins typing without dropdown
            if (val.length > 0 && !val.startsWith("PC-") && $("#projectCodePreset").val() === "PC-") {
                let newVal = "PC-" + val.replace(/^PC-/, "");
                $(this).val(newVal);

                this.setSelectionRange(newVal.length, newVal.length);
            }
        });


