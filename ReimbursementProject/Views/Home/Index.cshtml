         //calling restore funtion
                function restoreDraftFromLocal() {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return;

            const data = JSON.parse(raw);

            $("#siteName").val(data.siteName || "");
            $("#projectCode").val(data.projectCode || "");

            if (!data.rows || !data.rows.length) return;

            data.rows.forEach(r => {
                addRow(r.date, r.type);

                const row = $("#expenseRows .expense-row").last();

                row.find(".km-cell").val(r.km);
                row.find(".qty-cell").val(r.qty);
                row.find(".from-cell").val(r.from);
                row.find(".to-cell").val(r.to);
                row.find(".time-cell").val(r.time);
                row.find(".description-cell").val(r.description);
                row.find(".transport-type-cell").val(r.transportType);
                row.find(".billtype-cell").val(r.billType).trigger("change");
                row.find(".sanctioned-cell").val(r.sanctioned);
                row.find(".claim-cell").val(r.claim);

                // restore fellows
                        if (Array.isArray(r.fellows) && r.fellows.length) {
            const chosen = row.data("chosen");

            r.fellows.forEach(f => {
                chosen.push({ empId: f.empId, name: f.name });
            });

            row.find(".qty-cell").val(chosen.length + 1);

            // render using same logic as normal add
            const selectedIdsWrapper = row.find(".selected-ids");
            selectedIdsWrapper.empty();
            chosen.forEach((x, index) => {
                selectedIdsWrapper.append(`
                    <span class="badge bg-primary me-1">
                        ${x.name} (${x.empId})
                        <span class="ms-1 text-warning fw-bold pointer remove-chip" data-index="${index}">×</span>
                    </span>
                `);
            });
        }


                recalcSanctionedForRow(row);
                highlightRow(row);
            });
        }
