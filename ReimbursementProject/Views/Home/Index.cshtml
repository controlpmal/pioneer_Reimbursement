                // delete row
                        row.find(".btn-delete").click(() => {
            row.remove();
            saveDraftToLocal();
        });

                // fellows autocomplete
                             // fellows autocomplete + quantity auto update
        const fellowsInput = row.find(".fellows-cell");
        const selectedIdsWrapper = row.find(".selected-ids");
        const qtyInput = row.find(".qty-cell");
                        row.data("chosen", []);
        const chosen = row.data("chosen");

        ;

        // RENDER selected members with remove (X)
        function renderSelected() {
            selectedIdsWrapper.empty();
            chosen.forEach((x, index) => {
                const chip = $(`
                    <span class="badge bg-primary me-1">
                        ${x.name} (${x.empId})
                        <span class="ms-1 text-warning fw-bold pointer remove-chip" data-index="${index}" style="cursor:pointer;">×</span>
                    </span>
                `);

                // remove chip event
                chip.find(".remove-chip").click(function () {
                    const i = $(this).data("index");
                    chosen.splice(i, 1);
                    qtyInput.val(Math.max(1, chosen.length + 1)); // quantity never below 1
                    renderSelected();
                      recalcSanctionedForRow(row);   // 🔥 FIX HERE
                });

                selectedIdsWrapper.append(chip);
            });
        }

        // autocomplete input
        fellowsInput.on("input", function () {
            const text = $(this).val().toLowerCase();
            const suggestions = employees
                .filter(e =>
                    (e.empName || e.EmpName || "").toLowerCase().includes(text) ||
                    (e.empID || e.EmpID || "").toLowerCase().includes(text)
                )
                .slice(0, 5);

            $(this).next(".autocomplete-list").remove();
            if (!suggestions.length) return;

            const list = $('<div class="autocomplete-list border bg-white position-absolute p-1" style="z-index:9999;max-width:280px"></div>');

            suggestions.forEach(s => {
                const name = s.empName ?? s.EmpName;
                const id = s.empID ?? s.EmpID;

                const item = $(`<div class="small py-1 pointer">${name} (${id})</div>`);

                item.on("click", async () => {
                    const date = row.find(".date-cell").val();
                    const type = row.find(".type-cell").val();

                    // check duplicate in DB
                    try {
                        const res = await axios.get("/api/Employee/check-duplicate", {
                            params: { empId: id, typeOfExpense: type, dateOfExpense: date }
                        });
                        if (res.data.exists) {
                            showError(`${name} already has an entry for ${date} (${type}).`);
                        }
                         if(type.toUpperCase().includes("PUBLIC TRANSPORT")){

                             if (!chosen.find(x => x.empId === id)) {

                                chosen.push({ empId: id, name });

                                // quantity = 1 (self) + number of fellows
                                qtyInput.val(chosen.length + 1);

                                renderSelected();
                                  recalcSanctionedForRow(row);   // 🔥 FIX HERE
                            }
                        }
                        else {
                            // add if not already selected
                            if (!chosen.find(x => x.empId === id)) {
                                chosen.push({ empId: id, name });

                                // quantity = 1 (self) + number of fellows
                                qtyInput.val(chosen.length + 1);

                                renderSelected();
                                  recalcSanctionedForRow(row);   // 🔥 FIX HERE
                            }
                        }
                    } catch (err) { console.error(err); }

                    fellowsInput.val("");
                    list.remove();
                });

                list.append(item);
            });

            $(this).after(list);
            setTimeout(() => $(document).one("click", () => list.remove()), 200);
        });

                // bill type toggle
                  // bill type toggle
        row.find(".billtype-cell").on("change", function () {
            if ($(this).val() === "with") {
                row.find(".upload-field").show();
            } else {
                row.find(".upload-field").hide();
                row.find(".file-cell").val("");
            }
        }).trigger("change");

        // validate file size and type with confirm
        row.find(".file-cell").on("change", async function () {
            const file = this.files[0];
            if (!file) return;

            // ✅ Allowed file types
            const allowedTypes = [
                "application/pdf",
                "image/jpeg",
                "image/jpg",
                "image/png",
                "application/vnd.ms-excel",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            ];

            if (!allowedTypes.includes(file.type)) {
                showError("This file type is not allowed. Please upload PDF, JPG/JPEG, or Excel files only.");
                $(this).val(""); // clear file input
                return;
            }

            const maxSizeMB = 1; // 1 MB
            const riskySizeKB = 500; // suggested safe size
            const maxSizeBytes = maxSizeMB * 1024 * 1024;

            if (file.size > maxSizeBytes) {
                // Show confirm message instead of error
                const result = await Swal.fire({
                    title: 'File too large!',
                    html: `This file is more than 1 MB. It may cause problems during submission.
                           It's recommended to use a file smaller than ${riskySizeKB} KB.
                           Do you want to continue anyway?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, risky but continue',
                    cancelButtonText: 'No, choose another file'
                });

                if (!result.isConfirmed) {
                    $(this).val(""); // clear input if user cancels
                }
            }
        });


                // km/qty change
                row.find(".km-cell, .qty-cell, .billtype-cell").on("input change", () => recalcSanctionedForRow(row));
                row.find(".claim-cell").on("input", () => highlightRow(row));

                $("#expenseRows").append(row);
                updateRowControls(row);
                        row.on("input change", "input, select", function () {
            saveDraftToLocal();
        });

            }

            function updateRowControls(row) {
                const type = row.find(".type-cell").val();
                if (isTravelType(type)) {
                    row.find(".km-cell").prop("disabled", false);
                    row.find(".from-cell, .to-cell").show();
                                             row.find(".time-cell").hide();
                                                row.find(".travel-fields1").hide();
                                                  // row.find(".description-cell").hide();
                                                  //   row.find(".travel-fields2").hide();
                }
                else if (isTransportType(type)) {
                    row.find(".km-cell").prop("disabled", true).val("").hide();
                    row.find(".from-cell, .to-cell").show();
                    row.find(".kmfield").hide();
                       row.find(".time-cell").hide();
                         row.find(".travel-fields1").hide();
                             // row.find(".description-cell").hide();
                             //                          row.find(".travel-fields2").hide();
                                                          // ✅ SHOW TRANSPORT TYPE FIELD
        row.find(".transport-type-field").show();


                }
                  else if(isOtherType(type)){
                                            row.find(".km-cell").prop("disabled", true).val("").hide();
                      row.find(".from-cell, .to-cell").hide();
                      row.find(".travel-fields").hide();
                      row.find(".time-cell").hide();
                        row.find(".travel-fields1").hide();
                          row.find(".description-cell").show();
                                                        row.find(".travel-fields2").show();
                  }

                else {
                    row.find(".km-cell").prop("disabled", true).val("").hide();
                    row.find(".from-cell, .to-cell").hide();
                    row.find(".travel-fields").hide();
                    row.find(".time-cell").show();
                        // row.find(".description-cell").hide();
                        //                               row.find(".travel-fields2").hide();
                                                          // ✅ HIDE when NOT PUBLIC TRANSPORT
        row.find(".transport-type-field").hide();
                }
                recalcSanctionedForRow(row);
            }

            async function fetchLimit(level, type, withBill) {
                try {
                    const res = await axios.get(expenseLimitsApi, { params: { level, type, withBill } });
                    return res.data?.maxLimit ?? 0;
                } catch { return 0; }
            }

            async function recalcSanctionedForRow(row) {
                const type = row.find(".type-cell").val();
                const withBill = row.find(".billtype-cell").val() === "with";
                const km = parseFloat(row.find(".km-cell").val() || 0);
                const qty = parseFloat(row.find(".qty-cell").val() || 0) || 1;

                const maxLimit = await fetchLimit(Level, type, withBill);
                let sanctioned = 0;
                if (isTravelType(type)) sanctioned = (km || 0) * (maxLimit || 0);
                else if(isHotelType(type)) sanctioned =  (maxLimit || 0);
                else sanctioned = (qty || 0) * (maxLimit || 0);

                row.find(".sanctioned-cell").val(sanctioned.toFixed(2));
                highlightRow(row);
            }

                  function highlightRow(row) {
            const claim = parseFloat(row.find(".claim-cell").val() || 0);
            const sanctioned = parseFloat(row.find(".sanctioned-cell").val() || 0);

            if (claim > sanctioned) row.addClass("over-claim");
            else row.removeClass("over-claim");
        }


            // clear/submit
                   $("#btnClear").click(function () {
            showConfirm("This will clear all expense rows. Do you want to continue?")
                .then((result) => {
                    if (result.isConfirmed) {

                        // 1️⃣ Clear UI
                        $("#expenseRows").empty();

                        // 2️⃣ Clear saved draft
                        localStorage.removeItem(STORAGE_KEY);

                        // 3️⃣ Reset row counter (important)
                        nextRowId = 0;
                    }
                });
        });



                    // Helper functions
        function showLoader() {
            $("#loadingOverlay").fadeIn(200);
        }
        function hideLoader() {
            $("#loadingOverlay").fadeOut(200);
        }
                function convertTo12HourFormat(time24) {
            if (!time24) return "";
            let [hour, minute] = time24.split(":").map(Number);
            const ampm = hour >= 12 ? "PM" : "AM";
            hour = hour % 12 || 12;
            return `${hour}:${minute.toString().padStart(2, "0")} ${ampm}`;
        }

        //submit button funtion call
                    $("#btnSubmit").click(async () => {

                                     const confirmed = await showConfirm("Do you want to submit all entries?");
        if (!confirmed.isConfirmed) return;


            const site = $("#siteName").val().trim();
            const project = $("#projectCode").val().trim();

            if (!site || !project) {
               showError("Please enter Site Name and Project Code.");

                return;
            }

            showLoader();

            const rows = [];
            const filesToSend = {};

            const EmpID = "@EmpID";
            const Level = "@Level";
            const IRB = "@IRB";

            let valid = true;

            // ✅ Use standard for...of to avoid jQuery.each() break issues
            const allRows = $("#expenseRows .expense-row").toArray();

            for (const tr of allRows) {
                const $tr = $(tr);
                const date = $tr.find(".date-cell").val();
                const type = $tr.find(".type-cell").val();
                const km = parseFloat($tr.find(".km-cell").val() || 0);
                const qty = parseInt($tr.find(".qty-cell").val() || 0) || 0;


                // extract fellow IDs safely
              // extract fellow IDs safely
                     const fellowIDs = Array.from($tr.find(".selected-ids .badge"))
        .map(badge => {
            let txt = $(badge).clone().children().remove().end().text().trim();
            // Removes the × part & keeps: "John (101)"
            return txt;
        })
        .filter(x => x !== "")
        .join(", ");


                const description = $tr.find(".description-cell").val();
                const time24 = $tr.find(".time-cell").val();
                const time = convertTo12HourFormat(time24);
                const from = $tr.find(".from-cell").val();
                const to = $tr.find(".to-cell").val();
                 const km1 = parseFloat($tr.find(".km-cell").val() || 0);
                  const transportType = $tr.find(".transport-type-cell").val();

                // 🧩 three-case logic
                     let travelLocation = "";

                        // 1. From → To
                        if (from && to) {
                            travelLocation += `${from} to ${to}`;
                        }

                        // 2. Transport Type
                        if (transportType) {
                            travelLocation += travelLocation
                                ? ` [${transportType}]`
                                : `[${transportType}]`;
                        }

                        // 3. Time
                        if (time) {
                            travelLocation += travelLocation
                                ? ` (${time})`
                                : `${time}`;
                        }

                        // 4. KM
                        if (km1) {
                            travelLocation += travelLocation
                                ? ` (${km1} KM)`
                                : `${km1} KM`;
                        }

                        // 5. Description
                        if (description) {
                            travelLocation += travelLocation
                                ? ` - ${description}`
                                : description;
                        }

                const billType = $tr.find(".billtype-cell").val();
                const sanctioned = parseFloat($tr.find(".sanctioned-cell").val() || 0);
                const claim = parseFloat($tr.find(".claim-cell").val() || 0);
                const fileInp = $tr.find(".file-cell")[0];

                // ✅ Validate
                if (!claim || claim <= 0) {
                    showError(`Claim amount is required for ${date} (${type}).`);

                    valid = false;
                    break;
                }

                if (billType === "with" && (!fileInp.files || !fileInp.files.length)) {
                    showError(`Please upload bill for ${date} (${type}).`);

                    valid = false;
                    break;
                }

                // ✅ store file reference
                let fileIndex = null;
                if (fileInp && fileInp.files && fileInp.files.length > 0) {
                    fileIndex = Object.keys(filesToSend).length;
                    filesToSend[fileIndex] = fileInp.files[0];
                }

                rows.push({
                    DateOfExpense: date,
                    TypeOfExpense: type,
                    KM: km,
                    Quantity: qty,
                    FellowMembers: fellowIDs,
                    TravelLocation: travelLocation,
                    BillType: billType,
                    SanctionedAmount: sanctioned,
                    ClaimAmount: claim,
                    FileIndex: fileIndex
                });
            }

            if (!valid) {
                hideLoader();
                return;
            }

            if (!rows.length) {
                showError("No rows added. Please add entries first.");

                hideLoader();
                return;
            }

            // ✅ build FormData safely
            const fd = new FormData();
            fd.append("EmpID", EmpID);
            fd.append("SiteName", site);
            fd.append("ProjectCode", project);
            fd.append("Level", Level);
            fd.append("IRB", IRB);
            fd.append("Rows", JSON.stringify(rows));

            // ✅ append all files
            for (const idx in filesToSend) {
                fd.append(`file_${idx}`, filesToSend[idx]);
            }

            try {
                const res = await axios.post("/api/Employee/submit", fd, {
                    headers: { "Content-Type": "multipart/form-data" }
                });

                hideLoader();

                if (res.data?.success) {
                   showSuccess("Expense saved in checked box confirm from there!");
                   localStorage.removeItem(STORAGE_KEY);

                    $("#expenseRows").empty();
                     window.location.href = "/Home/Dashboard";
                } else {
                    showError("Save failed: " + (res.data?.message || "Unknown error"));

                }
            } catch (err) {
                hideLoader();
                console.error(err);
                showError("An error occurred while saving.");

            }
        });
              
            restoreDraftFromLocal();
  
          // ✅ last line inside document ready

        });

                 // Success Alert
        function showSuccess(msg) {
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: msg,
                showConfirmButton: false,
                timer: 1500
            });
        }

        // Error Alert
        function showError(msg) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: msg
            });
        }

        // Confirmation Alert (returns promise)
        function showConfirm(msg) {
            return Swal.fire({
                title: 'Are you sure?',
                text: msg,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes',
                cancelButtonText: 'No'
            });
        }
    </script>
}
