@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4><i class="fas fa-user-circle"></i> Employee Login</h4>
                </div>
                <div class="card-body">

                    <!-- 🔹 Forgot Password Panel (hidden by default) -->
                    <div id="forgotPasswordBox" class="border rounded-4 p-3 mb-3 d-none">
                        <h6 class="text-primary text-center mb-3"><i class="fas fa-lock"></i> Reset Password</h6>

                        <!-- Step 1: Enter Employee ID -->
                        <div id="stepEmpId">
                            <input type="text" id="forgotEmpId" class="form-control mb-2 rounded-pill" placeholder="Enter Employee ID" />
                            <button class="btn btn-outline-primary w-100 rounded-pill" onclick="sendOtp()">Send OTP</button>
                        </div>

                        <!-- Step 2: Enter OTP -->
                        <div id="stepOtp" class="d-none">
                            <input type="text" id="otpInput" class="form-control mb-2 rounded-pill" placeholder="Enter OTP" />
                            <button class="btn btn-outline-success w-100 rounded-pill" onclick="verifyOtp()">Verify OTP</button>
                        </div>

                        <!-- Step 3: Reset Password -->
                        <div id="stepReset" class="d-none">

                            <div class="input-group mb-2 rounded-pill">
                                <input type="password" id="newPassword" class="form-control rounded-pill" placeholder="New Password" />
                                <button class="btn" type="button" id="toggleNewPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>

                            <div class="input-group mb-2 rounded-pill">
                                <input type="password" id="confirmPassword" class="form-control rounded-pill" placeholder="Confirm Password" />
                                <button class="btn" type="button" id="toggleConfirmPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>

                            <button class="btn btn-success w-100 rounded-pill" onclick="resetPassword()">Reset Password</button>
                        </div>



                        <p id="forgotMsg" class="text-center mt-2 fw-semibold"></p>
                    </div>
                    <!-- 🔹 End Forgot Password Panel -->
                    <!-- 🔹 Normal Login Form -->
                    <div id="loginBox">
                        <form onsubmit="login(); return false;">
                        <div class="form-group mb-3">
                            <label for="empId"><i class="fas fa-id-badge"></i> Employee ID</label>
                            <input type="text" id="empId" class="form-control rounded-pill" placeholder="Enter Employee ID" />
                        </div>

                        <div class="form-group mb-3">
                            <label for="password"><i class="fas fa-key"></i> Password</label>
                            <div class="input-group rounded-pill">
                                <input type="password" id="password" class="form-control rounded-pill" placeholder="Enter Password" />
                                <button class="btn" type="button" id="togglePassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary rounded-pill" >
                                <i class="fas fa-sign-in-alt"></i> Login
                            </button>
                            <a class="btn btn-outline-secondary rounded-pill" asp-controller="Home" asp-action="Register">
                                <i class="fas fa-user-plus"></i>New employee register here
                            </a>
                        </div>
                        </form>

                        <div class="text-center mt-2">
                            <a href="#" onclick="showForgotPassword()">Forgot Password?</a>
                        </div>

                        <p id="error" class="text-danger mt-3 text-center"></p>
                        <p id="success" class="text-success mt-3 text-center"></p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loader Overlay -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="loading-box">
        <img src="https://i.gifer.com/ZZ5H.gif" alt="loading" class="loading-icon" />
        <p class="loading-text">Loading...</p>
    </div>
</div>

<style>
    .loading-overlay {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(6px);
        background: rgba(255, 255, 255, 0.3);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 2000;
    }

    .loading-box {
        background: rgba(255, 255, 255, 0.8);
        padding: 30px 40px;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        text-align: center;
        animation: floaty 2s ease-in-out infinite;
    }

    @@keyframes floaty {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-6px);
        }
    }

    .loading-icon {
        width: 64px;
        height: 64px;
        margin-bottom: 12px;
    }

    .loading-text {
        font-size: 16px;
        font-weight: 500;
        color: #333;
    }
</style>

<script>
    // Show Forgot Password UI
    function showForgotPassword() {
        document.getElementById("loginBox").classList.add("d-none");
        document.getElementById("forgotPasswordBox").classList.remove("d-none");
        document.getElementById("stepEmpId").classList.remove("d-none");
        document.getElementById("stepOtp").classList.add("d-none");
        document.getElementById("stepReset").classList.add("d-none");
        document.getElementById("forgotMsg").innerText = "";
    }

    function showLoader() { document.getElementById("loadingOverlay").style.display = "flex"; }
    function hideLoader() { document.getElementById("loadingOverlay").style.display = "none"; }

       // Toggle for New Password
    document.getElementById("toggleNewPassword").addEventListener("click", function () {
        const input = document.getElementById("newPassword");
        const icon = this.querySelector("i");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("fa-eye", "fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("fa-eye-slash", "fa-eye");
        }
    });

    // Toggle for Confirm Password
    document.getElementById("toggleConfirmPassword").addEventListener("click", function () {
        const input = document.getElementById("confirmPassword");
        const icon = this.querySelector("i");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("fa-eye", "fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("fa-eye-slash", "fa-eye");
        }
    });

        // Toggle for Login Password
    document.getElementById("togglePassword").addEventListener("click", function () {
        const input = document.getElementById("password");
        const icon = this.querySelector("i");
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("fa-eye", "fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("fa-eye-slash", "fa-eye");
        }
    });

   


    // ==============================
    // 🔹 FORGOT PASSWORD LOGIC
    // ==============================
    async function sendOtp() {
        const empId = document.getElementById("forgotEmpId").value.trim();
        const msg = document.getElementById("forgotMsg");
        if (!empId) {
            msg.innerText = "Please enter your Employee ID.";
            msg.className = "text-danger text-center mt-2";
            return;
        }

        try {
            showLoader();
            const res = await axios.post("/api/Employee/forgot-password", `"${empId}"`, {
                headers: { "Content-Type": "application/json" }
            });
            msg.innerText = res.data.message;
            msg.className = "text-success text-center mt-2";
            document.getElementById("stepEmpId").classList.add("d-none");
            document.getElementById("stepOtp").classList.remove("d-none");
        } catch (err) {
            msg.innerText = err.response?.data?.message || "Failed to send OTP.";
            msg.className = "text-danger text-center mt-2";
        } finally {
            hideLoader();
        }
    }

    async function verifyOtp() {
        const otp = document.getElementById("otpInput").value.trim();
        const msg = document.getElementById("forgotMsg");
        if (!otp) {
            msg.innerText = "Enter the OTP received on email.";
            msg.className = "text-danger text-center mt-2";
            return;
        }

        try {
            showLoader();
            const res = await axios.post("/api/Employee/verify-otp", `"${otp}"`, {
                headers: { "Content-Type": "application/json" }
            });
            if (res.data.success) {
                msg.innerText = "OTP verified! Please set a new password.";
                msg.className = "text-success text-center mt-2";
                document.getElementById("stepOtp").classList.add("d-none");
                document.getElementById("stepReset").classList.remove("d-none");
            } else {
                msg.innerText = res.data.message || "Invalid OTP.";
                msg.className = "text-danger text-center mt-2";
            }
        } catch (err) {
            msg.innerText = err.response?.data?.message || "OTP verification failed.";
            msg.className = "text-danger text-center mt-2";
        } finally {
            hideLoader();
        }
    }

    async function resetPassword() {
        const newPass = document.getElementById("newPassword").value.trim();
        const confirmPass = document.getElementById("confirmPassword").value.trim();
        const msg = document.getElementById("forgotMsg");

        if (!newPass || !confirmPass) {
            msg.innerText = "Please fill both password fields.";
            msg.className = "text-danger text-center mt-2";
            return;
        }
        if (newPass !== confirmPass) {
            msg.innerText = "Passwords do not match.";
            msg.className = "text-danger text-center mt-2";
            return;
        }

        try {
            showLoader();
            const res = await axios.post("/api/Employee/reset-password", { newPassword: newPass });
            msg.innerText = res.data.message || "Password reset successful!";
            msg.className = "text-success text-center mt-2";
            if (res.data.success) {
                setTimeout(() => window.location.reload(), 1500);
            }
        } catch (err) {
            msg.innerText = err.response?.data?.message || "Password reset failed.";
            msg.className = "text-danger text-center mt-2";
        } finally {
            hideLoader();
        }
    }

    // ==============================
    // 🔹 LOGIN LOGIC (unchanged)
    // ==============================
        async function login() {
        const empId = document.getElementById("empId").value.trim();
        const password = document.getElementById("password").value.trim();

        if (!empId || !password) {
            showError("Please enter Employee ID and Password.");
            return;
        }

        try {
            showLoader();

            const res = await axios.post("/api/Employee/DoLogin", {
                EmpId: empId,
                Password: password
            });

            if (res.data && res.data.success) {

                hideLoader();
                showSuccess("Login successful!");

                // Redirect after a short delay
                setTimeout(() => {
                    window.location.href = res.data.redirectUrl || "/Home/Dashboard";
                }, 1500);

            } else {
                hideLoader();
                showError(res.data?.message || "Invalid login details.");
            }

        } catch (err) {
            hideLoader();

            console.error(err);
            const msg = err.response?.data?.message || "Error connecting to server.";
            showError(msg);
        }
    }


    //alert message
     //alert message
        // Success Alert
    function showSuccess(msg) {
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: msg,
            showConfirmButton: false,
            timer: 1500
        });
    }

    // Error Alert
    function showError(msg) {
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: msg
        });
    }

    // Confirmation Alert (returns promise)
    function showConfirm(msg) {
        return Swal.fire({
            title: 'Are you sure?',
            text: msg,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes',
            cancelButtonText: 'No'
        });
    }
</script>
