@model ReimbursementProject.Models.ExpenseLogBook
@{
    var typeList = ViewData["TypeList"] as List<ReimbursementProject.Models.TypeOfExpenses>;
}

<div class="col-lg-4 col-md-6 col-sm-12 expense-card">
    <div class="card shadow-sm border-0 rounded-4 h-100">
        <div class="card-body">
            <div class="mb-2">
                <label class="form-label fw-semibold">Date of Expense</label>
                <input type="date" class="form-control form-control-sm expense-date" value="@Model.DateofExpense?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Type of Expense</label>
                <select class="form-select form-select-sm type-select" onchange="updateSanctionedAmount(this)">
                    <option value="">Select Type</option>
                    @foreach (var t in typeList)
                    {
                        <option value="@t.TypeOfExpense" selected="@(t.TypeOfExpense == Model.TypeOfExpense)">
                            @t.TypeOfExpense
                        </option>
                    }
                </select>
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Travel Location</label>
                <input type="text" class="form-control form-control-sm travel-location" value="@Model.TravelLocation" />
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Quantity</label>
                <input type="number" class="form-control form-control-sm quantity-input" value="@Model.Quantity" min="1" />
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Fellow Members</label>
                <input type="text" class="form-control form-control-sm fellow-members"
                       placeholder="Type name to search..." value="@Model.FellowMembers" list="employeeList" />
                <datalist id="employeeList">
                    @foreach (var e in ViewBag.EmployeeList as List<ReimbursementProject.Models.EmployeeDetails>)
                    {
                        <option value="@($"{e.EmpName} ({e.EmpID})")" />
                    }
                </datalist>
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Claim Amount</label>
                <input type="number" step="0.01" class="form-control form-control-sm claim-amount" value="@Model.ClaimAmount" />
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Bill Document</label>
                <input type="file" class="form-control form-control-sm bill-input" accept=".jpg,.jpeg,.png,.pdf,.xls,.xlsx" onchange="updateSanctionedAmount(this.closest('.expense-card').querySelector('.type-select'))" />
                @if (!string.IsNullOrEmpty(Model.BillFileName))
                {
                    <small class="text-muted">Existing: @Model.BillFileName</small>
                }
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold">Sanctioned Amount</label>
                <input type="number" class="form-control form-control-sm sanctioned-amount" readonly value="@Model.SanctionedAmount" />
            </div>
        </div>
    </div>
</div>
