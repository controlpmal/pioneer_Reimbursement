@model ReimbursementProject.Models.TypeOfExpenses
@{

    var designationClaim = User.FindFirst("Designation")?.Value ?? "";
}

<script>
    // Access control based on session claim
    const designation = "@designationClaim";
    if (designation.toUpperCase() !== "HR") {
        window.location.href = "/Home/Dashboard";
    }
</script>

<div class="container mt-4">
    <div class="card shadow col-md-6 mx-auto">
        <div class="card-header bg-warning">
            <h5>Edit Expense Type</h5>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="ID" />

                <div class="mb-3">
                    <label asp-for="TypeOfExpense" class="form-label"></label>
                    <input asp-for="TypeOfExpense" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>
