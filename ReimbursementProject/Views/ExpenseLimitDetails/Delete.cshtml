@model ReimbursementProject.Models.ExpenseLimitDetails


@{

    var designationClaim = User.FindFirst("Designation")?.Value ?? "";
}

<script>
    // Access control based on session claim
    const designation = "@designationClaim";
    if (designation.toUpperCase() !== "HR") {
        window.location.href = "/Home/Dashboard";
    }
</script>
<div class="container mt-4">
    <div class="card shadow col-md-8 mx-auto border-danger">
        <div class="card-header bg-danger text-white">
            <h5>Confirm Delete</h5>
        </div>

        <div class="card-body">
            <p>Are you sure you want to delete this expense limit?</p>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="ID" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
